# ─────────────────────────────────────────────────────────────
# .env — Secret keys and credentials
# NEVER commit this file to GitHub. It's in .gitignore already.
# Copy this file: cp .env.example .env  then fill in your values
# ─────────────────────────────────────────────────────────────

# Groq API Key (required)
# Get free key at: console.groq.com
GROQ_API_KEY="your api"

# Slack Incoming Webhook (required if slack.enabled: true in config)
# Get from: api.slack.com/apps → Your App → Incoming Webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Email / Gmail SMTP (required if email.enabled: true in config)
# For Gmail: use App Password (not your regular password)
# Generate at: myaccount.google.com → Security → 2FA → App Passwords
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your_app_password_here

# Database URL (required only if data_source.type: sql)
# PostgreSQL: postgresql://username:password@localhost:5432/your_db
# MySQL:      mysql+pymysql://username:password@localhost:3306/your_db
DATABASE_URL=postgresql://user:password@localhost:5432/ops_db
